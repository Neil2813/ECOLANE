DATABASE_URL=postgresql://user:password@host:5432/ecolens
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=72
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
HUGGINGFACE_API_KEY=your_hf_key_here
