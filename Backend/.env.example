ERA5_DATA_PATH=./data/era5_latest.nc
OSM_GRAPH_PATH=./data/bengaluru_osm.graphml
WEBPUSH_VAPID_PRIVATE_KEY=your_vapid_private_key
WEBPUSH_VAPID_PUBLIC_KEY=your_vapid_public_key
